%% TPU canary orchestrator -- 4-tier architecture
%% Source spec: ../SPEC.md (section "Architecture")

flowchart TD
    subgraph T1["Tier 1: Orchestrator (this session)"]
        SM[State Machine]
    end
    subgraph T2["Tier 2: Custom Droids"]
        WD[tpu-watchdog]
        DG[tpu-diagnoser]
    end
    subgraph T3["Tier 3: Skills"]
        SO[tpu-orchestrate]
        SR[tpu-redeploy]
    end
    subgraph T4["Tier 4: Background"]
        BG[orch_poll.py]
        CK[scheduled_checkin.py]
    end
    SM -.invokes.-> WD
    SM -.invokes.-> DG
    SM -.loads.-> SO
    SM -.loads.-> SR
    SM -.reads.-> CK
    BG -.writes.-> Log[orch_poll.log]
    WD -.reads.-> Log
    CK -.reads.-> Log
